<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:text="@string/sheet_title"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/optionShare"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/sheet_option_share"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/optionFavorite"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/sheet_option_favorite"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/optionCancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/sheet_option_cancel"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="16sp" />

</LinearLayout>
